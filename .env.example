DISCORD_TOKEN=your-token-here
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional but useful
DISCORD_CLIENT_ID=your-app-id
# Only if implementing HTTP Interactions (web) slash commands
DISCORD_PUBLIC_KEY=your-public-key
# Timezone (recommended for Docker/NAS). Example: Australia/Adelaide
# Precedence: TIMEZONE (config.yaml, if set to explicit value) > BOT_TIMEZONE > TZ > container/system local timezone.
# Keep BOT_TIMEZONE set for deterministic app + log timestamps across hosts.
BOT_TIMEZONE=Australia/Adelaide
# Optional container-level fallback if BOT_TIMEZONE is unset
TZ=